# 1Password SSH agent for all hosts
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  
# Home Hosts
Host mbp home.gcc.io
  HostName home.gcc.io
